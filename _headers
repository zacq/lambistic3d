# Netlify _headers file — reinforces headers for all browsers
# (netlify.toml headers take precedence; this is a fallback)

/hero/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/sction1/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/css/*.css
  Cache-Control: public, max-age=86400

/js/*.js
  Cache-Control: public, max-age=86400

/index.html
  Cache-Control: public, max-age=0, must-revalidate
